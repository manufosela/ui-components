{
  "name": "@manufosela/element-card",
  "version": "3.0.0",
  "description": "Card component with title, description, cover image and slotted grid content, built with Lit 3",
  "license": "MIT",
  "author": "manufosela",
  "type": "module",
  "main": "./src/element-card.js",
  "module": "./src/element-card.js",
  "types": "./src/element-card.d.ts",
  "exports": {
    ".": {
      "types": "./src/element-card.d.ts",
      "import": "./src/element-card.js"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "web-dev-server --node-resolve --open demo/ --watch",
    "test": "web-test-runner",
    "test:watch": "web-test-runner --watch",
    "test:coverage": "web-test-runner --coverage",
    "build:types": "tsc --declaration --declarationMap --emitDeclarationOnly --allowJs --checkJs --outDir ./src ./src/element-card.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/manufosela/ui-components",
    "directory": "packages/element-card"
  },
  "keywords": [
    "web-components",
    "lit",
    "card",
    "ui"
  ],
  "homepage": "https://github.com/manufosela/ui-components/tree/main/packages/element-card#readme",
  "bugs": {
    "url": "https://github.com/manufosela/ui-components/issues"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "customElements": "custom-elements.json"
}
